# ── Database (Supabase PostgreSQL) ─────────────────────────────────────────
# Pooler URL (port 6543, transaction mode) — for runtime queries via Prisma Client
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct URL (port 5432, session mode) — for Prisma Migrate
DIRECT_DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].supabase.com:5432/postgres"

# ── Upstash Redis (rate limiting & caching) ────────────────────────────────
UPSTASH_REDIS_REST_URL="https://[endpoint].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[token]"

# ── Resend (transactional email) ───────────────────────────────────────────
RESEND_API_KEY="re_[key]"

# ── Pinecone (vector database for AI features) ─────────────────────────────
PINECONE_API_KEY="[key]"
PINECONE_INDEX="maa-btool"

# ── App-level secrets ──────────────────────────────────────────────────────
JWT_SECRET="[generate-with: openssl rand -base64 32]"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Optional: Vercel Blob (file uploads) ───────────────────────────────────
# BLOB_READ_WRITE_TOKEN="[vercel-blob-token]"
