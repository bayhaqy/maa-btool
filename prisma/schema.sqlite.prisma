generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 1. IAM & SECURITY DOMAIN
// ============================================================

model TenantCompany {
  id            String   @id @default(cuid())
  companyCode   String   @unique
  companyName   String
  description   String?
  logoUrl       String?
  website       String?
  industry      String?
  parentCode    String?
  address       String?
  phone         String?
  email         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users       SysUser[]
  dataRecords DataRecord[]
  apiKeys     ApiKey[]
  sftpConfigs SftpConfig[]
}

model SysUser {
  id           String   @id @default(cuid())
  companyId    String
  username     String   @unique
  email        String   @unique
  passwordHash String
  displayName  String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company      TenantCompany  @relation(fields: [companyId], references: [id])
  userRoles    UserRole[]
  approvalTicketsRequested ApprovalTicket[] @relation("RequestedBy")
  approvalTicketsReviewed ApprovalTicket[]  @relation("ReviewedBy")
  asyncJobs    AsyncBatchJob[]
  lockedRecords DataRecord[]   @relation("LockedBy")
  dataVersions DataVersion[]
  docArticles  Documentation[]
  aiMessages   AiMessage[]
  aiConversations AiConversation[]
  apiKeys      ApiKey[]
  auditLogs    AuditLog[] @relation("AuditLogUser")
  savedViews      SavedView[]
  bulkUpdateJobs  BulkUpdateJob[]
  stewardshipAssigned StewardshipTask[] @relation("StewardshipAssignee")
  stewardshipCreated  StewardshipTask[] @relation("StewardshipAssigner")
}

model SysRole {
  id          String  @id @default(cuid())
  roleName    String  @unique
  description String?
  roleType    String  @default("DATA") // DATA, DOC, API, SFTP, AI, SYSTEM

  userRoles        UserRole[]
  rolePermissions  RolePermission[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user   SysUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   SysRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id                 String  @id @default(cuid())
  roleId             String
  moduleId           String
  canRead            Boolean @default(false)
  canWrite           Boolean @default(false)
  canDelete          Boolean @default(false)
  canApprove         Boolean @default(false)
  columnRestrictions String?
  rowFilter          String?

  role   SysRole    @relation(fields: [roleId], references: [id], onDelete: Cascade)
  module MetaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([roleId, moduleId])
}

// ============================================================
// 2. METADATA & SCHEMA ENGINE
// ============================================================

model MetaModule {
  id              String  @id @default(cuid())
  moduleCode      String  @unique
  moduleName      String
  moduleIcon      String  @default("Database")
  description     String?
  requireApproval Boolean @default(true)
  isActive        Boolean @default(true)
  sortOrder       Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  fields          MetaField[]
  dataRecords     DataRecord[]
  hierarchyModels HierarchyModel[]
  rolePermissions RolePermission[]
  sftpConfigs     SftpConfig[]
  businessRules   BusinessRule[]
  savedViews      SavedView[]
  bulkUpdateJobs  BulkUpdateJob[]
  stewardshipTasks StewardshipTask[]
}

model MetaField {
  id           String @id @default(cuid())
  moduleId     String
  fieldCode    String
  fieldName    String
  dataType     String // TEXT, NUMBER, DATE, BOOLEAN, SELECT, MULTISELECT, EMAIL, URL, LOOKUP, IMAGE
  isRequired   Boolean @default(false)
  isUnique     Boolean @default(false)
  defaultValue String?
  placeholder  String?
  description  String?
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
  // Cascading dropdown: when set, this SELECT/LOOKUP field's options are filtered
  // by the value of the field whose fieldCode === cascadesFromFieldCode (within
  // the same module). The lookupMaster.values are filtered where parentValueCode
  // matches the parent field's current value. Enables Category -> SubCategory.
  // isMultiple: for IMAGE type, allow multiple images per field value
  isMultiple          Boolean @default(false)
  cascadesFromFieldCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  module       MetaModule        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  validations  FieldValidation[]
  lookupId     String?
  lookupMaster LookupMaster?     @relation(fields: [lookupId], references: [id])

  @@unique([moduleId, fieldCode])
}

model FieldValidation {
  id           String  @id @default(cuid())
  fieldId      String
  ruleType     String
  ruleValue    String
  errorMessage String?
  createdAt    DateTime @default(now())

  field MetaField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
}

model LookupMaster {
  id          String   @id @default(cuid())
  lookupCode  String   @unique
  lookupName  String
  description String?
  category    String?  // System / Custom / ISO (for grouping)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  fields MetaField[]
  values LookupValue[]
}

model LookupValue {
  id           String    @id @default(cuid())
  lookupId     String
  valueCode    String
  displayValue String
  description  String?
  // Cascading lookup support: a child value (e.g. "Sepatu Running") can point
  // to a parent value (e.g. "Sepatu") via parentValueId (FK) and parentValueCode
  // (denormalized for fast filter & seed imports). Both nullable so existing
  // flat lookups continue to work unchanged.
  parentValueId   String?
  parentValueCode String?
  validFrom    DateTime?
  validTo      DateTime?
  isActive     Boolean   @default(true)
  sortOrder    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  lookup LookupMaster @relation(fields: [lookupId], references: [id], onDelete: Cascade)
  parent LookupValue? @relation("LookupValueTree", fields: [parentValueId], references: [id], onDelete: SetNull)
  children LookupValue[] @relation("LookupValueTree")

  @@unique([lookupId, valueCode])
}

// ============================================================
// 3. CORE DATA & AUDIT (SCD Type 2)
// ============================================================

model DataRecord {
  id             String   @id @default(cuid())
  moduleId       String
  companyId      String
  status         String   @default("DRAFT")
  currentPayload String
  lockedBy       String?
  version        Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdById    String?
  updatedById    String?

  module          MetaModule      @relation(fields: [moduleId], references: [id])
  company         TenantCompany   @relation(fields: [companyId], references: [id])
  locker          SysUser?        @relation("LockedBy", fields: [lockedBy], references: [id])
  versions        DataVersion[]
  approvalTickets ApprovalTicket[]
  hierarchyNodes  HierarchyNode[]
  images          ImageAsset[]
  stewardshipTasks StewardshipTask[]
}

model DataVersion {
  id              String   @id @default(cuid())
  recordId        String
  payloadSnapshot String
  versionNumber   Int
  changedById     String?
  changeReason    String?
  status          String
  validFrom       DateTime @default(now())
  validTo         DateTime?
  createdAt       DateTime @default(now())

  record    DataRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  changedBy SysUser?   @relation(fields: [changedById], references: [id])
}

// ============================================================
// 4. HIERARCHY ENGINE
// ============================================================

model HierarchyModel {
  id            String   @id @default(cuid())
  moduleId      String
  hierarchyName String
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module MetaModule    @relation(fields: [moduleId], references: [id])
  nodes  HierarchyNode[]
}

model HierarchyNode {
  id               String   @id @default(cuid())
  hierarchyId      String
  recordId         String?
  parentNodeId     String?
  nodeLabel        String
  materializedPath String   @default("")
  depthLevel       Int      @default(0)
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
  status           String   @default("DRAFT") // DRAFT / IN_REVIEW / ACTIVE / ARCHIVED
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  hierarchy HierarchyModel  @relation(fields: [hierarchyId], references: [id], onDelete: Cascade)
  record    DataRecord?     @relation(fields: [recordId], references: [id])
  parent    HierarchyNode?  @relation("HierarchyTree", fields: [parentNodeId], references: [id])
  children  HierarchyNode[] @relation("HierarchyTree")
}

// ============================================================
// 5. WORKFLOW & ASYNC JOBS
// ============================================================

model ApprovalTicket {
  id            String    @id @default(cuid())
  recordId      String
  requestedById String
  reviewedById  String?
  status        String    @default("PENDING")
  deltaPayload  String?
  reviewNotes   String?
  createdAt     DateTime  @default(now())
  reviewedAt    DateTime?

  // Multi-step workflow support
  workflowType  String    @default("SIMPLE") // SIMPLE, MULTI_STEP, PARALLEL
  currentStep   Int       @default(1)
  totalSteps    Int       @default(1)
  stepName      String?   // name of the current step
  deadline      DateTime? // SLA deadline for this step
  escalatedTo   String?   // user ID for escalation
  delegatedFrom String?   // original reviewer who delegated
  priority      String    @default("NORMAL") // LOW, NORMAL, HIGH, URGENT
  parentTicketId String?  // for parallel workflows, link to parent ticket
  workflowHistory String? // JSON array of {step, userId, action, timestamp, notes}

  record      DataRecord @relation(fields: [recordId], references: [id])
  requestedBy SysUser    @relation("RequestedBy", fields: [requestedById], references: [id])
  reviewedBy  SysUser?   @relation("ReviewedBy", fields: [reviewedById], references: [id])
  childTickets ApprovalTicket[] @relation("ParallelWorkflow")
  parentTicket ApprovalTicket? @relation("ParallelWorkflow", fields: [parentTicketId], references: [id])
}

model WorkflowTemplate {
  id           String   @id @default(cuid())
  name         String
  description  String?
  moduleScope  String?  // module code or null for global
  stepCount    Int      @default(1)
  stepConfig   String   // JSON array of {name, assigneeRole, deadlineHours, isParallel}
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AsyncBatchJob {
  id            String    @id @default(cuid())
  userId        String
  moduleId      String?
  jobType       String
  status        String    @default("PENDING")
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  failedRows    Int       @default(0)
  errorLog      String?
  fileName      String?
  resultFileUrl String?
  createdAt     DateTime  @default(now())
  completedAt   DateTime?

  user SysUser @relation(fields: [userId], references: [id])
}

// ============================================================
// 6. IMAGE ASSET MANAGEMENT
// ============================================================

model ImageAsset {
  id        String   @id @default(cuid())
  recordId  String
  fieldName String?
  fileName  String
  filePath  String
  fileSize  Int      @default(0)
  mimeType  String   @default("image/png")
  altText   String?
  sortOrder Int      @default(0)
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  variants ImageVariant[]

  record DataRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
}

// File storage in database (for Vercel serverless / read-only filesystem)
// Stores binary file data for both record images and documentation uploads
model FileAsset {
  id        String   @id @default(cuid())
  fileName  String
  fileData  Bytes
  mimeType  String   @default("application/octet-stream")
  fileSize  Int      @default(0)
  category  String   @default("general") // "image", "doc", "attachment"
  createdAt DateTime @default(now())
}

// ============================================================
// 7. API INTEGRATION MANAGEMENT
// ============================================================

model ApiKey {
  id          String    @id @default(cuid())
  keyName     String
  keyHash     String
  keyPrefix   String
  companyId   String?
  userId      String?
  permissions String
  rateLimit   Int       @default(100)
  isActive    Boolean   @default(true)
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  company    TenantCompany? @relation(fields: [companyId], references: [id])
  user       SysUser?       @relation(fields: [userId], references: [id])
  accessLogs ApiAccessLog[]
}

model ApiAccessLog {
  id          String   @id @default(cuid())
  apiKeyId    String
  endpoint    String
  method      String
  statusCode  Int
  responseMs  Int
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  apiKey ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
}

// ============================================================
// 8. SFTP INTEGRATION MANAGEMENT
// ============================================================

model SftpConfig {
  id             String    @id @default(cuid())
  configName     String
  host           String
  port           Int       @default(22)
  username       String
  authType       String    @default("PASSWORD")
  authCredential String
  remotePath     String    @default("/")
  schedule       String?
  syncDirection  String    @default("INBOUND")
  filePattern    String    @default("*.*")
  moduleId       String?
  isActive       Boolean   @default(true)
  lastSyncAt     DateTime?
  companyId      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  module    MetaModule?    @relation(fields: [moduleId], references: [id])
  company   TenantCompany? @relation(fields: [companyId], references: [id])
  syncLogs  SftpSyncLog[]
}

model SftpSyncLog {
  id            String    @id @default(cuid())
  sftpConfigId  String
  syncStatus    String
  filesSynced   Int       @default(0)
  filesFailed   Int       @default(0)
  errorDetail   String?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?

  sftpConfig SftpConfig @relation(fields: [sftpConfigId], references: [id], onDelete: Cascade)
}

// ============================================================
// 9. DOCUMENTATION / KNOWLEDGE BASE
// ============================================================

model Documentation {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  content     String
  category    String
  tags        String?
  authorId    String?
  version     Int       @default(1)
  sortOrder   Int       @default(0)
  isPublished Boolean   @default(false)
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author SysUser? @relation(fields: [authorId], references: [id])
}

// ============================================================
// 10. AI ASSISTANT
// ============================================================

model AppSettings {
  id          String   @id @default(cuid())
  settingKey  String   @unique
  settingValue String
  updatedById String?
  updatedAt   DateTime @updatedAt
}

// ============================================================
// 10b. AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  moduleName  String?
  description String
  oldValues   String?
  newValues   String?
  companyId   String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        SysUser? @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
}

model AiConversation {
  id           String    @id @default(cuid())
  userId       String
  title        String?
  bookmarked   Boolean   @default(false)
  bookmarkedAt DateTime?
  pinned       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user     SysUser    @relation(fields: [userId], references: [id])
  messages AiMessage[]
}

model AiMessage {
  id             String   @id @default(cuid())
  conversationId String
  userId         String?
  role           String
  content        String
  tokensUsed     Int      @default(0)
  createdAt      DateTime @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         SysUser?       @relation(fields: [userId], references: [id])
}

// ============================================================
// 11. BUSINESS RULES (STIBO Business Rules — cross-field validation)
// Extends per-field FieldValidation with module-level cross-field
// rules: Attribute Value Comparison, LOV Cross-Validation, OR/NOT
// composition, and actions (BLOCK / SET_VALUE / SEND_EMAIL).
// ============================================================

model BusinessRule {
  id            String   @id @default(cuid())
  moduleId      String
  name          String
  description   String?
  // Condition type: CROSS_FIELD (compare two fields), LOV_CROSS (parent-child LOV),
  // SCRIPTED (custom JS expression), REQUIRED_IF (conditional required)
  conditionType String   @default("CROSS_FIELD")
  // JSON: { leftFieldCode, operator, rightFieldCode | constantValue }
  // operator: = | != | > | < | >= | <= | contains | starts_with | ends_with | is_empty | is_not_empty
  conditionJson String
  // Action: BLOCK (prevent save), SET_VALUE (compute a field), SEND_EMAIL, WARN
  actionType    String   @default("BLOCK")
  // JSON for SET_VALUE: { targetFieldCode, expression } using {{field}} placeholders
  // JSON for SEND_EMAIL: { to, subject, bodyTemplate }
  actionJson    String?
  errorMessage  String?
  // Trigger: SAVE | APPROVE | IMPORT | TRANSITION
  trigger       String   @default("SAVE")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module MetaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

// ============================================================
// 12. SAVED VIEWS & SAVED SEARCHES (STIBO User Configurable Views + Sharing Saved Searches)
// Persists per-user column sets, sort, group-by, and the advanced
// multi-column filter (Task 23-D AdvancedFilter[] shape) so it can
// be named, re-applied, and shared with other users.
// ============================================================

model SavedView {
  id          String   @id @default(cuid())
  userId      String
  moduleId    String
  name        String
  // scope: COLUMNS (visible columns + widths + sort + groupBy) | SEARCH (advanced filter) | COMBINED
  scope       String   @default("COMBINED")
  // JSON: { columns: [{fieldCode, width}], sort: [{fieldCode, dir}], groupBy: [fieldCode] }
  columnConfig String?
  // JSON: AdvancedFilter[] (matches Task 23-D shape)
  filterConfig String?
  // Sharing: comma-separated user IDs, or "*" for all users in company, or null = private
  sharedWith   String?
  isDefault    Boolean  @default(false)
  lastUsedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    SysUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  module  MetaModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

// ============================================================
// 13. BULK UPDATE ENGINE (STIBO Bulk Updates — wizard-driven)
// Target a set of records via the advanced filter, apply ordered
// operations (SET_VALUE, CLEAR, MERGE, SET_NAME, SET_STATUS, RUN_RULE),
// with Preview (dry-run first 10), Pre-flight (full dry-run + failed list),
// and background-process monitoring.
// ============================================================

model BulkUpdateJob {
  id            String    @id @default(cuid())
  userId        String
  moduleId      String
  name          String?
  // JSON: AdvancedFilter[] (target selection — same shape as SavedView.filterConfig)
  targetFilter  String
  // JSON: [{ operation: 'SET_VALUE'|'CLEAR'|'MERGE'|'SET_NAME'|'SET_STATUS'|'RUN_RULE', fieldCode?, value?, config? }]
  operations    String
  status        String    @default("QUEUED") // QUEUED | PREVIEWING | RUNNING | COMPLETED | FAILED | CANCELLED
  mode          String    @default("APPLY")  // PREVIEW (dry-run first 10) | PREFLIGHT (full dry-run) | APPLY
  totalRecords  Int       @default(0)
  okRecords     Int       @default(0)
  failedRecords Int       @default(0)
  // JSON: [{ recordId, ok, before, after, error }]
  results       String?
  errorLog      String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user   SysUser    @relation(fields: [userId], references: [id])
  module MetaModule @relation(fields: [moduleId], references: [id])
}

// ============================================================
// 14. AI PROMPT LIBRARY + GENAI REVIEW (STIBO ProductGen AI)
// Governed AI enrichment: prompt templates (PTTT02-05, GAIDGRP01-02,
// Translation, ImageAltText, etc.) with persona/audience/tone,
// confidence scoring, and a review workflow (PENDING_REVIEW →
// APPROVED → CopyToTarget, or REJECTED).
// ============================================================

model AiPrompt {
  id              String   @id @default(cuid())
  name            String
  // STIBO use-case code: PTTT02, PTTT03, PTTT04, PTTT05, GAIDGRP01, GAIDGRP02,
  // TRANSLATION, IMAGE_ALT_TEXT, IMAGE_EXTRACT_TEXT, IMAGE_FULL_DESC, IMAGE_SEO_KEYWORDS
  useCase         String
  description     String?
  systemPrompt    String
  userPromptTemplate String
  // JSON: [fieldCode] — input attributes injected into the prompt
  inputAttributes  String?
  // target field code where approved output is copied
  outputAttribute String?
  maxChars        Int      @default(500)
  persona         String?
  audience        String?
  tone            String?
  language        String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  outputs AiOutput[]
}

model AiOutput {
  id              String   @id @default(cuid())
  promptId        String
  recordId        String
  userId          String?
  output          String
  // LLM-returned confidence 0-100 + reasons + correction suggestions
  confidenceScore Int      @default(0)
  reasons         String?
  suggestions     String?  // JSON array of strings
  status          String   @default("PENDING_REVIEW") // PENDING_REVIEW | APPROVED | REJECTED
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  tokensUsed      Int      @default(0)
  createdAt       DateTime @default(now())

  prompt AiPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model AiUsageMetric {
  id          String   @id @default(cuid())
  userId      String?
  promptId    String?
  tokensUsed  Int      @default(0)
  timestamp   DateTime @default(now())
}

// ============================================================
// 15. IMAGE VARIANTS (STIBO Image Conversion Configuration)
// Pre-computed resized/format-converted variants per ImageAsset
// (thumbnail 150px, small 300px, medium 800px, large 1200px) to
// cut grid bandwidth ~95% vs serving originals.
// ============================================================

model ImageVariant {
  id          String   @id @default(cuid())
  imageId     String
  // variant: thumbnail | small | medium | large | original
  variant     String
  filePath    String
  width       Int      @default(0)
  height      Int      @default(0)
  bytes       Int      @default(0)
  format      String   @default("webp")
  createdAt   DateTime @default(now())

  image ImageAsset @relation(fields: [imageId], references: [id], onDelete: Cascade)
}

// ============================================================
// 16. DATA QUALITY SUFFICIENCY (STIBO Data Governance)
// Per-record quality score (0-100, green/yellow/red) computed from
// Completeness + Value + Function metrics. Enables STIBO's
// "Below Title Sufficiency Card" pattern.
// ============================================================

model DataQualityScore {
  id          String   @id @default(cuid())
  recordId    String
  moduleId    String
  // metric: COMPLETENESS | VALUE | BUSINESS_RULE | OVERALL
  metricType  String   @default("OVERALL")
  metricCode  String?
  score       Int      @default(0)  // 0-100
  message     String?
  calculatedAt DateTime @default(now())

  @@unique([recordId, metricType, metricCode])
}

// ============================================================
// 17. DATA STEWARDSHIP (STIBO Data Governance)
// Tasks assigned to data stewards for reviewing, correcting,
// and enriching data. Derived from quality issues, approval
// workflows, or manual assignment.
// ============================================================

model StewardshipTask {
  id          String    @id @default(cuid())
  moduleId    String
  recordId    String?
  taskType    String    @default("QUALITY_REVIEW") // QUALITY_REVIEW | OWNERSHIP_ASSIGN | DATA_CORRECTION | ENRICHMENT | DEDUP_REVIEW
  title       String
  description String?
  priority    String    @default("NORMAL") // LOW | NORMAL | HIGH | URGENT
  status      String    @default("PENDING") // PENDING | IN_PROGRESS | COMPLETED | CANCELLED | ESCALATED
  assignedTo  String?
  assignedBy  String?
  dueDate     DateTime?
  completedAt DateTime?
  resolution  String?
  // JSON: additional context (quality issue details, suggested fixes, etc.)
  context     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  module      MetaModule @relation(fields: [moduleId], references: [id])
  record      DataRecord? @relation(fields: [recordId], references: [id])
  assignee    SysUser?   @relation("StewardshipAssignee", fields: [assignedTo], references: [id])
  assigner    SysUser?   @relation("StewardshipAssigner", fields: [assignedBy], references: [id])
}
