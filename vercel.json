{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "bash build.sh",
  "installCommand": "bun install",
  "devCommand": "bun run dev",
  "regions": ["sin1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/home", "destination": "/", "permanent": true },
    { "source": "/dashboard", "destination": "/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/health" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), browsing-topics=()"
        },
        {
          "key": "X-DNS-Prefetch-Control",
          "value": "on"
        }
      ]
    },
    {
      "source": "/_next/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*\\.(?:png|jpg|jpeg|gif|webp|avif|svg|ico|woff|woff2|ttf|eot|css|js|map))",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "src/app/api/ai/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/images/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "src/app/api/r2-populate/**/*.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/r2-migrate/**/*.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/uploads/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/seed/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/seed-data/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/admin/reseed-map-data/**/*.ts": {
      "memory": 1024,
      "maxDuration": 120
    },
    "src/app/api/admin/migrate-cascading/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/documents/**/*.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "src/app/api/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "crons": [],
  "git": {
    "deploymentEnabled": true
  }
}
